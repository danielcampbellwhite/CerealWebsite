# Copy to `.env` and fill in. Never commit `.env`.

# --- Database ---
# Dev: SQLite file via Node's built-in node:sqlite (default: ./data/cereal.db).
# Override the path if you want:
# DATABASE_PATH="./data/cereal.db"

# --- Admin login (single-admin) — used in Milestone 3 ---
# The password you type at /admin to publish combos.
ADMIN_PASSWORD="change-me"
# A long random string used to sign the admin session cookie.
SESSION_SECRET="change-me-to-a-long-random-string"

# --- Cloudinary (photo uploads) — added in Milestone 3 ---
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
